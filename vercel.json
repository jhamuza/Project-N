{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' 'unsafe-inline' https: data: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https: blob:;"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/NCEF-Portal-Bundle.html" },
    { "source": "/(.*)", "destination": "/NCEF-Portal-Bundle.html" }
  ]
}
